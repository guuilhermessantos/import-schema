# ============================================================================
# CONFIGURAÇÃO SSH - Servidor Remoto
# ============================================================================
REMOTE_SSH_HOST=
REMOTE_SSH_USER=
REMOTE_SSH_KEY_PATH=.pem
REMOTE_EXPORT_SCRIPT=/exportar-schema.sh
REMOTE_SSH_PORT=22

# ============================================================================
# Schema padrão a exportar se nenhum for especificado (opcional, padrão: public)
# ============================================================================
DEFAULT_SCHEMA=public

# ============================================================================
# CONFIGURAÇÃO PostgreSQL - Banco Local
# ============================================================================
LOCAL_PGHOST=localhost
LOCAL_PGPORT=5432
LOCAL_PGDATABASE=postgres
LOCAL_PGUSER=postgres
LOCAL_PGPASSWORD=postgres